	   ${TAR} -C ${WRKDIR} -xf ${DISTDIR}/$$F.tar.${COMPEXT}\
	     --no-same-owner --no-same-permissions;\
	   ${SETENV} ${CONFIGURE_ENV} ${LOCALBASE}/bin/bash ${WRKDIR}/$$F/install.sh\
