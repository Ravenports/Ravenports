[FILE:575:files/aria2.conf.sample.in]
# Basic Settings
dir=%%PREFIX%%/var/db/aria2
continue=true
max-concurrent-downloads=5
max-connection-per-server=16
min-split-size=20M
split=10
disable-ipv6=false

# Advanced Settings
file-allocation=falloc
log-level=warn
log=%%PREFIX%%/var/log/aria2/aria2.log

# BitTorrent Settings
bt-max-peers=55
enable-dht=true
enable-peer-exchange=true
seed-ratio=1.0
seed-time=0

# RPC Settings (for Web UIs like AriaNg)
enable-rpc=true
rpc-allow-origin-all=true
rpc-listen-all=true
rpc-listen-port=6800
# It is highly recommended to set a secret token
# rpc-secret=YourSecureTokenHere


[FILE:691:files/aria2.in]
#!/bin/sh
#
# PROVIDE: aria2
# REQUIRE: NETWORKING
# KEYWORD: shutdown

#
# Add the following lines to /etc/rc.conf to enable aria2:
#
# aria2_enable="YES"
#
# You can define flags for aria2 running. See aria2c(1) for details.
#

. /etc/rc.subr

name=aria2
rcvar=aria2_enable

command=%%PREFIX%%/bin/aria2c

# read configuration and set defaults
load_rc_config $name
aria2_enable=${aria2_enable:-"NO"}
aria2_config=${aria2_config:-"%%PREFIX%%/etc/aria2.conf"}
aria2_flags=${aria2_flags:-""}
aria2_user=${aria2_user:-"%%ARIA2_USR%%"}
aria2_group=${aria2_group:-"%%ARIA2_GRP%%"}

required_files=${aria2_config}
command_args="-D --conf-path=${aria2_config} ${aria2_flags}"

run_rc_command "$1"


