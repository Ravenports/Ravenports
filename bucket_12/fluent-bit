<?xml version="1.0"?>
<!DOCTYPE service_bundle SYSTEM "/usr/share/lib/xml/dtd/service_bundle.dtd.1">
<service_bundle type="manifest" name="%%SMF_NAME%%">
    <service name="%%SMF_PREFIX%%/%%SMF_NAME%%" type="service" version="1">
        <create_default_instance enabled="false"/>
        <single_instance/>
        <dependency name="network" grouping="require_all" restart_on="error" type="service">
            <service_fmri value="svc:/milestone/network:default"/>
        </dependency>
        <dependency name="filesystem" grouping="require_all" restart_on="error" type="service">
            <service_fmri value="svc:/system/filesystem/local"/>
        </dependency>
        <dependency name='config-file' grouping='require_all' restart_on='refresh' type='path'>
            <service_fmri value='file://localhost%%PREFIX%%/etc/fluent-bit/fluent-bit.conf'/>
        </dependency>
        <exec_method type="method" name="start"
            exec='/usr/bin/bash -c "exec %%PREFIX%%/bin/fluent-bit --config=%{config_file} -l %%PREFIX%%/var/log/fluent-bit/service.log &amp;"'
            timeout_seconds="60">
            <method_context working_directory="%%PREFIX%%/var/run/fluent-bit">
                 <method_credential user="%%SRV_USR%%" group="%%SRV_GRP%%"/>
            </method_context>
        </exec_method>
        <exec_method type="method" name="stop"
            exec='/usr/bin/pkill -9 -u fluent -f "%%PREFIX%%/bin/fluent-bit"'
            timeout_seconds="60"/>
        <property_group name="startd" type="framework">
            <propval name="duration" type="astring" value="contract"/>
            <propval name="ignore_error" type="astring" value="core,signal"/>
        </property_group>
        <property_group name="application" type="application">
            <propval name="config_file" type="astring" value="%%PREFIX%%/etc/fluent-bit/fluent-bit.conf"/>
        </property_group>
        <stability value="Evolving"/>
        <template>
            <common_name>
                <loctext xml:lang="C">
                    Fluent Bit logging and data forwarder
                </loctext>
            </common_name>
        </template>
    </service>
</service_bundle>

